NODE_ENV=development
PORT=5001

MONGODB_URI=mongodb://localhost:27017/edunext

JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CORS_ORIGIN=http://localhost:5000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required in production for real video/image/PDF uploads. Without all three,
# uploads silently save a `placeholder.edunext.dev` URL in development, and
# the server refuses to start in production (see server/src/app.js).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Enables real AI features (recommendations, quiz generation, course
# summaries, AI Tutor chatbot) via Google Gemini. Without it, AI endpoints
# return clearly-labelled stub responses — safe for local dev, not for
# production.
GEMINI_API_KEY=

# Required in production for transactional email (welcome, enrollment
# confirmation, verification, password reset). Without it, emails are only
# logged to the console — fine for local dev, not for production.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@edunext.com
